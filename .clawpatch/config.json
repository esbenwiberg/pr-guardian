{
  "schemaVersion": 1,
  "stateDir": ".clawpatch",
  "include": [
    "**/*"
  ],
  "exclude": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "target/**",
    ".build/**",
    ".git/**",
    ".clawpatch/**",
    ".venv/**",
    "__pycache__/**",
    "**/*.pyc",
    "alembic/versions/**",
    "prototypes/**",
    ".speclint-cache/**",
    "*.egg-info/**"
  ],
  "provider": {
    "name": "codex",
    "model": null,
    "reasoningEffort": null
  },
  "commands": {
    "typecheck": "mypy src",
    "lint": "ruff check .",
    "format": "ruff format --check .",
    "test": "python -m pytest"
  },
  "review": {
    "maxContextFiles": 24,
    "maxOwnedFiles": 12,
    "maxFindingsPerFeature": 10,
    "minConfidenceToFix": "medium"
  },
  "git": {
    "requireCleanWorktreeForFix": true,
    "commit": false,
    "openPr": false
  }
}
