# PR Guardian — Environment Variables
# Copy this to .env and fill in your values

# Database
DB_PASSWORD=change-me-in-production

# LLM Provider (set at least one)
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI (alternative to Anthropic)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_KEY=...

# GitHub (runtime API auth is configured via GitHub App Connections in /profiles)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Azure DevOps (for ADO webhook integration)
# ADO_PAT=...
# ADO_ORG_URL=https://dev.azure.com/yourorg
