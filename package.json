{
  "name": "pr-guardian",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend build for PR Guardian dashboard (Tool Design System + Tailwind CSS)",
  "scripts": {
    "build:css": "tailwindcss -c tailwind.config.js -i src/pr_guardian/dashboard/src/input.css -o src/pr_guardian/dashboard/static/styles.css --minify",
    "dev:css": "tailwindcss -c tailwind.config.js -i src/pr_guardian/dashboard/src/input.css -o src/pr_guardian/dashboard/static/styles.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
